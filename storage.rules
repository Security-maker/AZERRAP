rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function role() { return signedIn() ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role : null; }
    function isSupervisor() { return role() in ['superviseur', 'admin']; }
    function isAdmin() { return role() == 'admin'; }

    match /reports/{reportId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }

    match /sites/{siteId}/{fileName} {
      allow read: if signedIn();
      allow write, delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
